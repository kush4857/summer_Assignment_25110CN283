#include <stdio.h>

void palindrome(int n)
{
    int rev = 0, rem, temp = n;

    while (n > 0)
    {
        rem = n % 10;
        rev = rev * 10 + rem;
        n = n / 10;
    }

    if (temp == rev)
        printf("Palindrome Number");
    else
        printf("Not a Palindrome Number");
}

int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);

    palindrome(num);

    return 0;
}

#include <stdio.h>

void armstrong(int n)
{
    int sum = 0, rem, temp = n;

    while (n > 0)
    {
        rem = n % 10;
        sum = sum + rem * rem * rem;
        n = n / 10;
    }

    if (sum == temp)
        printf("Armstrong Number");
    else
        printf("Not an Armstrong Number");
}

int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);

    armstrong(num);

    return 0;
}

#include <stdio.h>

void fibonacci(int n)
{
    int a = 0, b = 1, c, i;

    for (i = 1; i <= n; i++)
    {
        printf("%d ", a);
        c = a + b;
        a = b;
        b = c;
    }
}

int main()
{
    int n;

    printf("Enter number of terms: ");
    scanf("%d", &n);

    fibonacci(n);

    return 0;
}

#include <stdio.h>

void perfect(int n)
{
    int i, sum = 0;

    for (i = 1; i < n; i++)
    {
        if (n % i == 0)
            sum = sum + i;
    }

    if (sum == n)
        printf("Perfect Number");
    else
        printf("Not a Perfect Number");
}

int main()
{
    int num;

    printf("Enter a number: ");
    scanf("%d", &num);

    perfect(num);

    return 0;
}
