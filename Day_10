#include <stdio.h>

int main() {
    int i, j, rows = 5;

    for(i = 1; i <= rows; i++) {
        // Print spaces
        for(j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print stars
        for(j = 1; j <= (2 * i - 1); j++) {
            printf("*");
        }

        printf("\n");
    }

    return 0;
}

#include <stdio.h>

int main() {
    int i, j, rows = 5;

    for(i = rows; i >= 1; i--) {
        // Print leading spaces
        for(j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print stars
        for(j = 1; j <= (2 * i - 1); j++) {
            printf("*");
        }

        printf("\n");
    }

    return 0;
}

#include <stdio.h>

int main() {
    int i, j, k, rows = 5;

    for(i = 1; i <= rows; i++) {
        // Print spaces
        for(j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print ascending numbers
        for(j = 1; j <= i; j++) {
            printf("%d", j);
        }

        // Print descending numbers
        for(k = i - 1; k >= 1; k--) {
            printf("%d", k);
        }

        printf("\n");
    }

    return 0;
}

#include <stdio.h>

int main() {
    int i, j, k, rows = 5;

    for(i = 1; i <= rows; i++) {

        // Print spaces
        for(j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print ascending characters
        for(j = 0; j < i; j++) {
            printf("%c", 'A' + j);
        }

        // Print descending characters
        for(k = i - 2; k >= 0; k--) {
            printf("%c", 'A' + k);
        }

        printf("\n");
    }

    return 0;
}
