#include <stdio.h>

int main() {
    int n, sum;

    printf("Enter a number  ");
    scanf("%d", &n);

    sum = n * (n + 1) / 2;

    printf("Sum of first %d natural numbers = %d", n, sum);

    return 0;
}
//multiplication table 
#include <stdio.h>

int main() {
    int num, i;

    printf("Enter a number: ");
    scanf("%d", &num);

    for(i = 1; i <= 10; i++) {
        printf("%d x %d = %d\n", num, i, num * i);
    }

    return 0;
}
//factorial
#include <stdio.h>

int main() {
    int num, i, factorial = 1;

    printf("Enter a number: ");
    scanf("%d", &num);

    for(i = 1; i <= num; i++) {
        factorial = factorial * i;
    }

    printf("Factorial of %d = %d\n", num, factorial);

    return 0;
}
//countthedigit
#include <stdio.h>

int main() {
    int num, count = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    while(num != 0) {
        num = num / 10;
        count++;
    }

    printf("Number of digits = %d\n", count);

    return 0;
}
